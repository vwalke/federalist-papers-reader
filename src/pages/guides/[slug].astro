---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import GazetteMasthead from '../../components/GazetteMasthead.astro';
import CuratedList from '../../components/CuratedList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOrderedGuides } from '../../lib/guides';
import '../../styles/guide.css';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { data } = guide;
const { Content } = await render(guide);

const allGuides = await getOrderedGuides();
const others = allGuides.filter((g) => g.id !== guide.id);
const hasPapers = data.papers.length > 0;

const pageURL = Astro.site ? new URL(`/guides/${guide.id}/`, Astro.site).href : undefined;
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: data.title,
  description: data.description,
  ...(pageURL ? { url: pageURL, mainEntityOfPage: pageURL } : {}),
  ...(hasPapers
    ? {
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: data.papers.map((p, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: `Federalist No. ${p.number}`,
            ...(Astro.site ? { url: new URL(`/papers/${p.number}/`, Astro.site).href } : {})
          }))
        }
      }
    : {})
};
---

<BaseLayout
  title={`${data.metaTitle ?? data.title} | Federalist Reader`}
  description={data.description}
  pageClass="guide-page"
  ogType="article"
  jsonLd={itemList}
>
  <article class="paper-sheet guide-page">
    <GazetteMasthead compact dateLine="A reader's companion" />

    <header class="guide-lead">
      <p class="section-kicker">{data.kicker}</p>
      <h1>{data.title}</h1>
      <p class="guide-lead__standfirst">{data.standfirst}</p>
      <span class="guide-lead__ornament" aria-hidden="true"></span>
    </header>

    <div class="guide-intro">
      <Content />
    </div>

    {hasPapers ? (
      <>
        <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>

        <CuratedList entries={data.papers} />

        <nav class="guide-crosslinks" aria-label="More guides">
          <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>
          <h2 class="guide-crosslinks__title">Further companions</h2>
          <ul>
            {others.map((g) => (
              <li><a href={`/guides/${g.id}/`}>{g.data.title}</a></li>
            ))}
          </ul>
        </nav>
      </>
    ) : (
      <>
        <p class="guide-cta">
          <a class="button-link" href="/papers/1/">Begin with Paper No. 1 <span aria-hidden="true">→</span></a>
        </p>

        <section class="guide-group" aria-labelledby="companions-title">
          <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>
          <h2 class="guide-group__title" id="companions-title">The companions</h2>
          <p class="guide-group__note">Five short guides, by essentials and by theme.</p>
          <ol class="curated-list">
            {others.map((g) => (
              <li class="curated-entry">
                <div class="curated-entry__body">
                  <h3 class="curated-entry__topic"><a href={`/guides/${g.id}/`}>{g.data.title}</a></h3>
                  <p class="curated-entry__why">{g.data.standfirst}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </>
    )}
  </article>
</BaseLayout>
