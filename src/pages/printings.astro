---
import GazetteMasthead from '../components/GazetteMasthead.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { printingImagePath, printings } from '../data/printings';
import '../styles/guide.css';

const description =
  'Original eighteenth-century newspaper printings of the Federalist Papers — the actual sheets, scanned in high resolution, courtesy of Seth Kaller, Inc.';

const pageURL = Astro.site ? new URL('/printings/', Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'The Print Room — Original Printings of the Federalist Papers',
  description,
  ...(pageURL ? { url: pageURL, mainEntityOfPage: pageURL } : {})
};

const federalistPrintings = printings.filter((printing) => printing.paperNumber !== null);
const contextPrintings = printings.filter((printing) => printing.paperNumber === null);
const entryId = (printing: (typeof printings)[number]) =>
  printing.paperNumber !== null ? `federalist-${printing.paperNumber}` : printing.slug;
---

<BaseLayout
  title="The Print Room — Original Printings | Federalist Reader"
  description={description}
  pageClass="printings-page"
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="paper-sheet printings-page">
    <GazetteMasthead compact dateLine="The print room" />

    <header class="guide-lead">
      <p class="section-kicker">Original printings</p>
      <h1>The print room</h1>
      <p class="guide-lead__standfirst">
        The actual newspapers. These essays were public arguments first, and a few of the very
        sheets that carried them survive.
      </p>
      <span class="guide-lead__ornament" aria-hidden="true"></span>
    </header>

    <div class="printings-intro">
      <p>
        Everything on this site restages the Federalist Papers; this page shows the real thing.
        The newspapers below passed through the hands of{' '}
        <a href="https://www.sethkaller.com/">Seth Kaller</a>, one of the country’s leading
        experts in original American documents, who scanned them in high resolution and let us
        share them here. The <a href="/about/">About page</a> tells the story of our visit with
        Seth; these images are the closest a screen can come to holding the paper.
      </p>
    </div>

    {federalistPrintings.map((printing, index) => (
      <>
        <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>
        <section class="printing" id={entryId(printing)} aria-labelledby={`${entryId(printing)}-title`}>
          <header class="printing__head">
            <p class="section-kicker">Federalist No. {printing.paperNumber}</p>
            <h2 id={`${entryId(printing)}-title`} class="printing__paper">{printing.newspaper}</h2>
            <p class="printing__imprint">{printing.imprint}</p>
          </header>

          <ul class="printing__sheets" role="list">
            {printing.pages.map((page) => (
              <li>
                <a
                  class="printing__sheet"
                  href={printingImagePath(printing, page.page, 'large', 'jpg')}
                  data-lightbox={printing.slug}
                  data-page={page.page}
                >
                  <picture>
                    <source
                      type="image/avif"
                      srcset={printingImagePath(printing, page.page, 'thumb', 'avif')}
                    />
                    <img
                      src={printingImagePath(printing, page.page, 'thumb', 'jpg')}
                      alt={page.alt}
                      width={page.thumb.w}
                      height={page.thumb.h}
                      loading={index === 0 && page.page === 1 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </picture>
                  <span class="printing__sheet-label" aria-hidden="true">
                    {page.page === 1 ? 'Front page' : `Page ${page.page}`}
                  </span>
                </a>
              </li>
            ))}
          </ul>

          <h3 class="printing__heading">{printing.heading}</h3>
          <div class="printing__caption">
            {printing.caption.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          {printing.excerpt && (
            <blockquote class="printing__excerpt">
              <p>“{printing.excerpt}”</p>
              <cite>Publius, Federalist No. {printing.paperNumber}</cite>
            </blockquote>
          )}
          <p class="printing__actions">
            <a class="button-link" href={`/papers/${printing.paperNumber}/`}>
              Read No. {printing.paperNumber} <span aria-hidden="true">→</span>
            </a>
          </p>
          {printing.rubenstein && (
            <p class="printing__credit">Collection of David M. Rubenstein.</p>
          )}
        </section>
      </>
    ))}

    <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>

    <section class="printings-context" aria-labelledby="context-heading">
      <header class="printing__head">
        <p class="section-kicker">Setting the stage</p>
        <h2 id="context-heading" class="printing__paper printing__paper--context">
          The debate around Publius
        </h2>
      </header>
      <p class="printings-context__intro">
        Two more survivors bracket the series: the week the Constitution went out to the states,
        and the winter Massachusetts argued over it.
      </p>

      {contextPrintings.map((printing) => (
        <section class="printing printing--context" id={entryId(printing)} aria-labelledby={`${entryId(printing)}-title`}>
          <header class="printing__head printing__head--context">
            <h3 id={`${entryId(printing)}-title`} class="printing__paper printing__paper--small">
              {printing.newspaper}
            </h3>
            <p class="printing__imprint">{printing.imprint}</p>
          </header>
          <ul class="printing__sheets printing__sheets--context" role="list">
            {printing.pages.map((page) => (
              <li>
                <a
                  class="printing__sheet"
                  href={printingImagePath(printing, page.page, 'large', 'jpg')}
                  data-lightbox={printing.slug}
                  data-page={page.page}
                >
                  <picture>
                    <source
                      type="image/avif"
                      srcset={printingImagePath(printing, page.page, 'thumb', 'avif')}
                    />
                    <img
                      src={printingImagePath(printing, page.page, 'thumb', 'jpg')}
                      alt={page.alt}
                      width={page.thumb.w}
                      height={page.thumb.h}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <span class="printing__sheet-label" aria-hidden="true">
                    {page.page === 1 ? 'Front page' : `Page ${page.page}`}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <h4 class="printing__heading printing__heading--context">{printing.heading}</h4>
          <div class="printing__caption">
            {printing.caption.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </section>
      ))}
    </section>

    <div class="guide-rule" aria-hidden="true"><span class="guide-rule__mark"></span></div>

    <footer class="printings-credits">
      <p>
        Images courtesy of{' '}
        <a href="https://www.sethkaller.com/">Seth Kaller, Inc.</a> Catalog research condensed
        from Seth Kaller’s descriptions, with gratitude.
      </p>
    </footer>
  </article>

  <dialog class="printing-lightbox" aria-label="Enlarged page view">
    <div class="printing-lightbox__frame">
      <img class="printing-lightbox__image" alt="" />
    </div>
    <p class="printing-lightbox__caption" aria-live="polite"></p>
    <div class="printing-lightbox__controls">
      <button type="button" class="printing-lightbox__button" data-direction="-1">
        <span aria-hidden="true">←</span> Previous page
      </button>
      <button type="button" class="printing-lightbox__button" data-close>Close</button>
      <button type="button" class="printing-lightbox__button" data-direction="1">
        Next page <span aria-hidden="true">→</span>
      </button>
    </div>
  </dialog>
</BaseLayout>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('.printing-lightbox');
  const image = dialog?.querySelector<HTMLImageElement>('.printing-lightbox__image');
  const caption = dialog?.querySelector<HTMLParagraphElement>('.printing-lightbox__caption');
  const thumbs = [...document.querySelectorAll<HTMLAnchorElement>('a[data-lightbox]')];

  if (dialog && image && caption) {
    let current = 0;
    let opener: HTMLAnchorElement | null = null;

    const show = (index: number) => {
      const thumb = thumbs[index];
      if (!thumb) return;
      current = index;
      const alt = thumb.querySelector('img')?.alt ?? '';
      image.src = thumb.href;
      image.alt = alt;
      caption.textContent = alt;
      const set = thumb.dataset.lightbox;
      for (const button of dialog.querySelectorAll<HTMLButtonElement>('[data-direction]')) {
        const target = thumbs[index + Number(button.dataset.direction)];
        button.disabled = target?.dataset.lightbox !== set;
      }
    };

    for (const [index, thumb] of thumbs.entries()) {
      thumb.addEventListener('click', (event) => {
        event.preventDefault();
        opener = thumb;
        show(index);
        dialog.showModal();
      });
    }

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
    dialog.querySelector('[data-close]')?.addEventListener('click', () => dialog.close());
    for (const button of dialog.querySelectorAll<HTMLButtonElement>('[data-direction]')) {
      button.addEventListener('click', () => show(current + Number(button.dataset.direction!)));
    }
    dialog.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft' || event.key === 'ArrowRight') {
        event.preventDefault();
        const target = thumbs[current + (event.key === 'ArrowLeft' ? -1 : 1)];
        if (target?.dataset.lightbox === thumbs[current]?.dataset.lightbox) {
          show(current + (event.key === 'ArrowLeft' ? -1 : 1));
        }
      }
    });
    dialog.addEventListener('close', () => {
      image.removeAttribute('src');
      opener?.focus();
    });
  }
</script>

<style>
  .printings-intro,
  .printings-context__intro {
    max-inline-size: 56ch;
    margin: var(--space-xl) auto 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .printing {
    margin-block-start: var(--space-xl);
  }

  .printing__head {
    text-align: center;
  }

  .printing__paper {
    margin: 0;
    font: 400 clamp(1.6rem, 3.4vw, 2.5rem) / 1.08 var(--font-period-display);
    letter-spacing: 0.01em;
  }

  .printing__paper--small {
    font-size: clamp(1.35rem, 2.6vw, 1.9rem);
  }

  .printing__imprint {
    margin: var(--space-2xs) 0 0;
    font-size: 0.95rem;
    color: var(--color-muted-ink);
    font-variant-numeric: oldstyle-nums;
  }

  .printing__sheets {
    display: flex;
    gap: var(--space-md);
    justify-content: safe center;
    list-style: none;
    margin: var(--space-lg) calc(-1 * var(--space-md)) 0;
    padding: var(--space-2xs) var(--space-md) var(--space-sm);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .printing__sheets li {
    flex: 0 0 auto;
  }

  .printing__sheet {
    display: block;
    inline-size: clamp(7.5rem, 18vw, 11rem);
    text-decoration: none;
    color: var(--color-muted-ink);
  }

  .printing__sheet img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--color-rule);
    box-shadow: 0 1px 4px oklch(0.19 0.018 70 / 0.18);
    background: var(--color-paper);
    transition: transform 150ms cubic-bezier(0.25, 1, 0.5, 1), box-shadow 150ms;
  }

  .printing__sheet:hover img,
  .printing__sheet:focus-visible img {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px oklch(0.19 0.018 70 / 0.24);
  }

  .printing__sheet-label {
    display: block;
    margin-block-start: var(--space-2xs);
    text-align: center;
    font-family: var(--font-sans, system-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .printing__heading {
    max-inline-size: 56ch;
    margin: var(--space-lg) auto 0;
    text-align: center;
    font: 400 clamp(1.3rem, 2.4vw, 1.7rem) / 1.15 var(--font-display);
  }

  .printing__heading--context {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
  }

  .printing__caption {
    max-inline-size: 56ch;
    margin-inline: auto;
  }

  .printing__caption p {
    margin-block-start: var(--space-md);
    font-size: 1.0625rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .printing__excerpt {
    max-inline-size: 48ch;
    margin: var(--space-lg) auto 0;
    padding-inline-start: var(--space-md);
    border-inline-start: 2px solid var(--color-rule);
  }

  .printing__excerpt p {
    margin: 0;
    font-family: var(--font-period-body);
    font-size: 1.15rem;
    line-height: 1.55;
  }

  .printing__excerpt cite {
    display: block;
    margin-block-start: var(--space-xs);
    font-style: normal;
    font-size: 0.9rem;
    color: var(--color-muted-ink);
    letter-spacing: 0.06em;
  }

  .printing__actions {
    margin: var(--space-lg) auto 0;
    text-align: center;
  }

  .printing__credit {
    margin: var(--space-md) auto 0;
    max-inline-size: 56ch;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-muted-ink);
    letter-spacing: 0.04em;
  }

  .printings-context .printing--context {
    margin-block-start: var(--space-2xl);
  }

  .printings-credits {
    max-inline-size: 56ch;
    margin: var(--space-xl) auto 0;
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-muted-ink);
  }

  .printing-lightbox {
    inline-size: min(94vw, 72rem);
    max-block-size: 94vh;
    padding: var(--space-md);
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .printing-lightbox::backdrop {
    background: oklch(0.16 0.015 70 / 0.82);
  }

  .printing-lightbox__frame {
    overflow: auto;
    max-block-size: calc(94vh - 8.5rem);
  }

  .printing-lightbox__image {
    display: block;
    inline-size: 100%;
    block-size: auto;
  }

  .printing-lightbox__caption {
    margin: var(--space-sm) 0 0;
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-muted-ink);
  }

  .printing-lightbox__controls {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-block-start: var(--space-sm);
    flex-wrap: wrap;
  }

  .printing-lightbox__button {
    min-block-size: 44px;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-rule);
    background: var(--color-newsprint);
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
    cursor: pointer;
  }

  .printing-lightbox__button:disabled {
    opacity: 0.4;
    cursor: default;
  }

  @media (prefers-reduced-motion: reduce) {
    .printing__sheet img {
      transition: none;
    }
    .printing__sheet:hover img,
    .printing__sheet:focus-visible img {
      transform: none;
    }
  }
</style>
