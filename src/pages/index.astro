---
import { getCollection } from 'astro:content';

import GazetteMasthead from '../components/GazetteMasthead.astro';
import IndexLedger from '../components/IndexLedger.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getOrderedPapers } from '../lib/papers';

import '../styles/index.css';

const papers = getOrderedPapers(await getCollection('papers').then((entries) =>
  entries.map((entry) => ({ ...entry, number: entry.data.number }))
));
---

<BaseLayout
  title="The Federalist Papers — Full Text and Summaries of All 85 Essays"
  description="Read all 85 Federalist Papers in an inviting period newspaper setting, with a clear modern reader and brief companion notes."
  pageClass="home-page"
>
  <article class="paper-sheet">
    <GazetteMasthead />

    <section class="home-intro" aria-labelledby="welcome-title">
      <div>
        <p class="home-intro__kicker">A reading edition for today</p>
        <h1 id="welcome-title">Read the debate in the form it first entered public life.</h1>
      </div>
      <p class="home-intro__copy">
        In 1787 and 1788, the essays of “Publius” arrived one by one in New York newspapers.
        This edition brings all eighty-five together with their original words, an optional clean
        reading view, and a little friendly context for the conversation afterward.
      </p>
      <p class="home-intro__action">
        <a class="button-link" href="/papers/1/" data-continue-link>
          <span data-continue-label>Begin with Paper No. 1</span> <span aria-hidden="true">→</span>
        </a>
      </p>
    </section>

    <section class="home-ways" aria-labelledby="reading-note-title">
      <header class="home-ways__head">
        <p class="section-kicker">How to read this edition</p>
        <h2 id="reading-note-title">Three ways to begin</h2>
      </header>
      <div class="home-ways__grid">
        <div class="home-ways__option">
          <h3>One paper at a time</h3>
          <p>
            The essays are most companionable at the pace their first readers knew: one argument,
            one cup of coffee, one conversation. Your progress stays privately in this
            browser&mdash;there is no account to create.
          </p>
          <p class="home-ways__action">
            <a href="/#all-papers">Browse the complete collection <span aria-hidden="true">↓</span></a>
          </p>
        </div>
        <div class="home-ways__option">
          <h3>Follow a companion</h3>
          <p>
            Short guides gather the essays everyone cites and trace the questions the series keeps
            returning to&mdash;faction, the division of power, the presidency, the courts.
          </p>
          <p class="home-ways__action">
            <a href="/guides/where-to-start/">Where to start <span aria-hidden="true">→</span></a>
          </p>
        </div>
        <div class="home-ways__option">
          <h3>Have it delivered</h3>
          <p>
            Publius can call at your address instead&mdash;one paper each Saturday, or each on the
            very date it first appeared. Confirmed by return post; leave whenever you like.
          </p>
          <p class="home-ways__action">
            <a href="/subscribe/">Subscribe by post <span aria-hidden="true">→</span></a>
          </p>
        </div>
      </div>
    </section>

    <IndexLedger papers={papers} />
  </article>
</BaseLayout>
