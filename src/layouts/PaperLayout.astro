---
import type { CollectionEntry } from 'astro:content';

import Commentary from '../components/Commentary.astro';
import EssayNavigation from '../components/EssayNavigation.astro';
import GazetteMasthead from '../components/GazetteMasthead.astro';
import PaperWear from '../components/PaperWear.astro';
import ReadingToolbar from '../components/ReadingToolbar.astro';
import { getPaperWear } from '../lib/paper-wear';
import { formatIssueDateline, toRomanNumeral } from '../lib/paper-display';
import BaseLayout from './BaseLayout.astro';

import '../styles/paper.css';

type Paper = CollectionEntry<'papers'>;

interface Props {
  paper: Paper;
  previous: Paper | null;
  next: Paper | null;
}

const { paper, previous, next } = Astro.props;
const { data } = paper;
const wear = getPaperWear(data.number);
const paperStyle = [
  `--wear-edge-a: ${wear.edgeDepth}%`,
  `--wear-edge-b: ${wear.edgeDepthAlt}%`
].join('; ');
---

<BaseLayout
  title={`Federalist No. ${data.number}: ${data.title} — Publius`}
  description={data.indexSummary}
  pageClass="essay-page"
  readingMode
>
  <article class="paper-sheet paper-page" data-paper-number={data.number} style={paperStyle}>
    <PaperWear number={data.number} />
    <GazetteMasthead
      compact
      dateLine={formatIssueDateline(data.publicationDate, data.publicationKind)}
    />
    <ReadingToolbar number={data.number} />

    <header class="essay-heading">
      <h1 class="essay-heading__title">
        <span>THE FEDERALIST.</span>{' '}
        <span class="essay-heading__number">No. {toRomanNumeral(data.number)}.</span>
      </h1>
      <p class="essay-heading__topic">{data.title}</p>
      <p class="essay-heading__recipient">{data.recipient}</p>
      <span class="essay-heading__ornament" aria-hidden="true"></span>
      <p class="essay-heading__byline">PUBLIUS</p>
      <p class="essay-heading__author">{data.author}</p>
      <p class="essay-heading__publication">{data.publicationDateLabel}</p>
      {data.authorCertainty === 'disputed' && (
        <p class="essay-heading__note">Authorship attribution is disputed.</p>
      )}
    </header>

    <div class="essay-body">
      <slot />
    </div>

    <Commentary
      nutshell={data.nutshell}
      keyArguments={data.keyArguments}
      whyItMattered={data.whyItMattered}
      talkItOver={data.talkItOver}
    />

    <EssayNavigation
      previous={previous ? { number: previous.data.number, title: previous.data.title } : null}
      next={next ? { number: next.data.number, title: next.data.title } : null}
    />
  </article>
</BaseLayout>
