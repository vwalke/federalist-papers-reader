---
import type { CollectionEntry } from 'astro:content';

import Commentary from '../components/Commentary.astro';
import EssayNavigation from '../components/EssayNavigation.astro';
import EssayShare from '../components/EssayShare.astro';
import GazetteMasthead from '../components/GazetteMasthead.astro';
import PaperWear from '../components/PaperWear.astro';
import ReadingToolbar from '../components/ReadingToolbar.astro';
import { getThemeGuidesForPaper } from '../lib/guides';
import { getPrintingForPaper, printingAnchor } from '../data/printings';
import SubscribePrompt from '../components/SubscribePrompt.astro';
import { formatIssueDateline, toRomanNumeral } from '../lib/paper-display';
import BaseLayout from './BaseLayout.astro';

import '../styles/paper.css';

type Paper = CollectionEntry<'papers'>;

interface Props {
  paper: Paper;
  previous: Paper | null;
  next: Paper | null;
}

const { paper, previous, next } = Astro.props;
const { data } = paper;

const paperURL = Astro.site
  ? new URL(`/papers/${data.number}/`, Astro.site).href
  : undefined;
const imageURL = Astro.site
  ? new URL(`/social-cards/${data.number}.jpg`, Astro.site).href
  : undefined;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: `Federalist No. ${data.number}: ${data.topic}`,
    description: data.indexSummary,
    author: { '@type': 'Person', name: data.author },
    datePublished: data.publicationDate,
    ...(paperURL ? { url: paperURL, mainEntityOfPage: paperURL } : {}),
    ...(imageURL ? { image: imageURL } : {}),
    isPartOf: { '@type': 'CreativeWorkSeries', name: 'The Federalist Papers' },
    publisher: { '@type': 'Organization', name: 'Federalist Reader' }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      Astro.site && {
        '@type': 'ListItem',
        position: 1,
        name: 'The Federalist Papers',
        item: new URL('/', Astro.site).href
      },
      paperURL && {
        '@type': 'ListItem',
        position: 2,
        name: `Federalist No. ${data.number}`,
        item: paperURL
      }
    ].filter(Boolean)
  }
];

const themeGuides = await getThemeGuidesForPaper(data.number);
const printing = getPrintingForPaper(data.number);
---

<BaseLayout
  title={`Federalist No. ${data.number}: ${data.topic} | Federalist Reader`}
  description={data.indexSummary}
  pageClass="essay-page"
  ogImage={`/social-cards/${data.number}.jpg`}
  ogType="article"
  jsonLd={structuredData}
  readingMode
>
  <article class="paper-sheet paper-page" data-paper-number={data.number}>
    <PaperWear number={data.number} />
    <GazetteMasthead
      compact
      dateLine={formatIssueDateline(data.publicationDate, data.publicationKind)}
    />
    <ReadingToolbar number={data.number} />

    <div class="essay-flow">
      <header class="essay-heading">
        <h1 class="essay-heading__title">
          <span>THE <span class="period-spelling" data-modern="FEDERALIST" data-gazette="FŒDERALIST" aria-label="FEDERALIST">FŒDERALIST</span>.</span>{' '}
          <span class="essay-heading__number">No. {toRomanNumeral(data.number)}.</span>
        </h1>
        <p class="essay-heading__topic">{data.title}</p>
        <p class="essay-heading__recipient">{data.recipient}</p>
      </header>

      <div class="essay-body">
        <slot />
      </div>
    </div>

    <Commentary
      author={data.author}
      authorCertainty={data.authorCertainty}
      nutshell={data.nutshell}
      keyArguments={data.keyArguments}
      whyItMattered={data.whyItMattered}
      talkItOver={data.talkItOver}
    />

    <div class="essay-coda">
      <EssayShare number={data.number} />
      <SubscribePrompt />
    </div>

    <EssayNavigation
      number={data.number}
      previous={previous ? { number: previous.data.number, title: previous.data.title } : null}
      next={next ? { number: next.data.number, title: next.data.title } : null}
    />

    {printing && (
      <aside class="essay-printing-link" aria-label="Original printing">
        <span class="section-kicker">The original printing</span>
        <p>
          One of the newspapers that carried this essay survives—{printing.proseName}.{' '}
          <a href={`/printings/#${printingAnchor(printing)}`}>See it in the print room</a>.
        </p>
      </aside>
    )}

    {themeGuides.length > 0 && (
      <nav class="essay-theme-link" aria-label="Related themes">
        <span class="section-kicker">Explore the theme</span>
        <ul>
          {themeGuides.map((g) => (
            <li><a href={`/guides/${g.id}/`}>{g.data.title}</a></li>
          ))}
        </ul>
      </nav>
    )}
  </article>
</BaseLayout>

<script>
  import { initEssayJustify } from '../lib/essay-justify';

  initEssayJustify();
</script>
