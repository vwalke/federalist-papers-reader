---
import '@fontsource/im-fell-english/latin-400.css';
import '@fontsource/im-fell-english/latin-400-italic.css';
import '@fontsource/im-fell-dw-pica/latin-400.css';
import '@fontsource/im-fell-dw-pica/latin-400-italic.css';
import '@fontsource/libre-caslon-display/latin-400.css';
import '@fontsource/libre-caslon-text/latin-400.css';
import '@fontsource/libre-caslon-text/latin-400-italic.css';
import '@fontsource/libre-caslon-text/latin-700.css';

import '../styles/global.css';
import '../styles/utilities.css';

import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  pageClass?: string;
  readingMode?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  pageClass = '',
  readingMode = false,
  ogImage = '/social-cards/default.jpg'
} = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
// Social crawlers require an absolute image URL; relative paths are dropped.
const ogImageURL = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html lang="en" data-reading-mode={readingMode ? 'gazette' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#26231f" />
    <meta name="color-scheme" content="light" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Federalist" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:site_name" content="Federalist Reader" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={title} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {readingMode && (
      <script is:inline>
        try {
          const savedMode = localStorage.getItem('publius:reading-mode');
          if (savedMode === 'reader') document.documentElement.dataset.readingMode = 'reader';
          const savedScale = Number(localStorage.getItem('publius:text-scale'));
          if ([1.12, 1.25, 1.4, 1.55].includes(savedScale)) {
            document.documentElement.style.setProperty('--reading-scale', String(savedScale));
          }
        } catch {}
      </script>
    )}
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-utility" aria-label="Site header">
      <a class="site-utility__home" href="/">Publius</a>
      <nav aria-label="Primary navigation">
        <a href="/#all-papers">All papers</a>
        <a href="/about/">About this edition</a>
      </nav>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <p>All eighty-five essays, made for reading together.</p>
      <nav aria-label="Footer navigation">
        <a href="/">The papers</a>
        <a href="/about/">About</a>
      </nav>
    </footer>
    <Analytics />
  </body>
</html>
