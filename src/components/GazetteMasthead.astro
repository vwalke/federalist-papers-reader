---
interface Props {
  dateLine?: string;
  compact?: boolean;
}

const {
  dateLine = 'New-York · The essays of Publius · 1787–1788',
  compact = false
} = Astro.props;
---

<header class:list={['gazette-masthead', { 'gazette-masthead--compact': compact }] }>
  <img
    class="gazette-masthead__art"
    src="/masthead-independent-journal.svg"
    alt=""
    width="1200"
    height="145"
  />
  <div class="gazette-masthead__issue">
    <span class="gazette-masthead__issue-rule" aria-hidden="true"></span>
    <p class="gazette-masthead__dateline">{dateLine}</p>
    <span class="gazette-masthead__issue-rule" aria-hidden="true"></span>
  </div>
</header>
