---
interface Props {
  eyebrow?: string;
  publicationName?: string;
  dateLine?: string;
  compact?: boolean;
}

const {
  eyebrow = 'Or, The General Advertiser',
  publicationName = 'The Independent Journal',
  dateLine = 'New-York · The essays of Publius · 1787–1788',
  compact = false
} = Astro.props;
---

<header class:list={['gazette-masthead', { 'gazette-masthead--compact': compact }] }>
  <p class="gazette-masthead__eyebrow">{eyebrow}</p>
  <p class="gazette-masthead__name">{publicationName}</p>
  <div class="gazette-masthead__rules" aria-hidden="true"><span>✦</span></div>
  <p class="gazette-masthead__dateline">{dateLine}</p>
</header>
