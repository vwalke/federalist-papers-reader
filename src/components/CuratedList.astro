---
import { getCollection } from 'astro:content';

interface Props {
  entries: { number: number; why: string }[];
}

const { entries } = Astro.props;
const papers = await getCollection('papers');
const byNumber = new Map(papers.map((p) => [p.data.number, p.data]));

const resolved = entries
  .map((entry) => ({ ...entry, paper: byNumber.get(entry.number) }))
  .filter((entry) => entry.paper);
---

<ol class="curated-list">
  {resolved.map((entry) => (
    <li class="curated-entry">
      <p class="curated-entry__eyebrow">Federalist No. {entry.number}</p>
      <h2 class="curated-entry__topic">{entry.paper!.topic}</h2>
      <p class="curated-entry__why">{entry.why}</p>
      <p class="curated-entry__link">
        <a href={`/papers/${entry.number}/`}>Read No. {entry.number} <span aria-hidden="true">→</span></a>
      </p>
    </li>
  ))}
</ol>
