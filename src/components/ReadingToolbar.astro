---
import ProgressControl from './ProgressControl.astro';

interface Props {
  number: number;
}

const { number } = Astro.props;
---

<nav class="reading-toolbar" aria-label={`Reading tools for Federalist No. ${number}`}>
  <a class="reading-toolbar__index" href="/#all-papers"><span aria-hidden="true">←</span> Index</a>
  <ProgressControl number={number} />
  <div class="reading-toolbar__modes" role="group" aria-label="Reading style">
    <button type="button" data-mode="gazette" aria-pressed="true">Gazette</button>
    <button type="button" data-mode="reader" aria-pressed="false">Reader</button>
  </div>
  <div class="reading-toolbar__scale">
    <span class="reading-toolbar__scale-letter" aria-hidden="true">A</span>
    <input
      class="reading-toolbar__scale-slider"
      type="range"
      min="0"
      max="4"
      step="1"
      value="0"
      aria-label="Text size"
      aria-valuetext="Standard"
      data-text-scale
    />
    <span
      class="reading-toolbar__scale-letter reading-toolbar__scale-letter--large"
      aria-hidden="true">A</span
    >
  </div>
</nav>

<script>
  import { createPreferences, TEXT_SCALE_STEPS } from '../lib/preferences';

  const root = document.documentElement;
  const modeButtons = document.querySelectorAll<HTMLButtonElement>('[data-mode]');
  const scaleSlider = document.querySelector<HTMLInputElement>('[data-text-scale]');
  const periodSpellings = document.querySelectorAll<HTMLElement>(
    '.period-spelling[data-modern][data-gazette]'
  );
  let storage: Storage | null = null;
  try {
    storage = window.localStorage;
  } catch {
    // Reader mode still works for this page when storage is blocked.
  }
  const preferences = createPreferences(storage);

  function applyPeriodSpellings(mode: 'gazette' | 'reader') {
    for (const spelling of periodSpellings) {
      const value = mode === 'reader' ? spelling.dataset.modern : spelling.dataset.gazette;
      if (value) spelling.textContent = value;
    }
  }

  function applyMode(mode: 'gazette' | 'reader') {
    root.dataset.readingMode = mode;
    for (const button of modeButtons) {
      button.setAttribute('aria-pressed', String(button.dataset.mode === mode));
    }
    applyPeriodSpellings(mode);
    preferences.setReadingMode(mode);
    // After the spelling swaps, so listeners measure the current text.
    document.dispatchEvent(new CustomEvent('publius:reading-changed', { detail: { mode } }));
  }

  const initialMode = root.dataset.readingMode === 'reader' ? 'reader' : 'gazette';
  applyMode(initialMode);

  for (const button of modeButtons) {
    button.addEventListener('click', () => applyMode(button.dataset.mode === 'reader' ? 'reader' : 'gazette'));
  }

  const SCALE_LABELS = ['Standard', 'Slightly larger', 'Large', 'Extra large', 'Largest'];

  function applyTextScale(stepIndex: number) {
    const scale = TEXT_SCALE_STEPS[stepIndex] ?? TEXT_SCALE_STEPS[0];
    root.style.setProperty('--reading-scale', String(scale));
    scaleSlider?.setAttribute('aria-valuetext', SCALE_LABELS[stepIndex] ?? SCALE_LABELS[0]);
    preferences.setTextScale(scale);
    document.dispatchEvent(new CustomEvent('publius:reading-changed', { detail: { scale } }));
  }

  if (scaleSlider) {
    const savedIndex = TEXT_SCALE_STEPS.indexOf(preferences.getTextScale());
    const initialIndex = savedIndex === -1 ? 0 : savedIndex;
    scaleSlider.value = String(initialIndex);
    applyTextScale(initialIndex);
    scaleSlider.addEventListener('input', () => applyTextScale(Number(scaleSlider.value)));
  }
</script>
