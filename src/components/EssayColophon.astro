---
import { toRomanNumeral } from '../lib/paper-display';
import ProgressControl from './ProgressControl.astro';

interface PaperLink {
  number: number;
  title: string;
}

interface Props {
  number: number;
  next: PaperLink | null;
}

const { number, next } = Astro.props;

const continueHref = next ? `/papers/${next.number}/` : '/#all-papers';
const unreadLabel = next ? 'Mark read & continue' : 'Mark read & return to the collection';
const readLabel = next ? `Continue to No. ${next.number}` : 'Return to the collection';
---

<aside class="essay-colophon" aria-label={`Finish Federalist No. ${number}`}>
  <span class="essay-colophon__ornament" aria-hidden="true">❧</span>
  <p class="essay-colophon__finis">Here ends No. {toRomanNumeral(number)}.</p>
  <div class="essay-colophon__actions">
    <ProgressControl number={number} />
    <a
      class="essay-colophon__continue"
      href={continueHref}
      data-continue-control={number}
      data-unread-label={unreadLabel}
      data-read-label={readLabel}
    >
      <span data-continue-label>{unreadLabel}</span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<script>
  import { createPreferences } from '../lib/preferences';

  let storage: Storage | null = null;
  try {
    storage = window.localStorage;
  } catch {
    // The combined action still marks read for this page view.
  }
  const preferences = createPreferences(storage);

  for (const anchor of document.querySelectorAll<HTMLAnchorElement>('[data-continue-control]')) {
    const number = Number(anchor.dataset.continueControl);
    const label = anchor.querySelector<HTMLElement>('[data-continue-label]');

    function render(read: boolean) {
      const text = read ? anchor.dataset.readLabel : anchor.dataset.unreadLabel;
      if (label && text) label.textContent = text;
    }

    render(preferences.isPaperRead(number));

    document.addEventListener('paper-read-change', (event) => {
      const detail = (event as CustomEvent<{ number: number; read: boolean }>).detail;
      if (detail.number === number) render(detail.read);
    });

    // localStorage writes are synchronous, so the mark lands before navigation.
    anchor.addEventListener('click', () => {
      preferences.setPaperRead(number, true);
    });
  }
</script>
