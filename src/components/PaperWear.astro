---
import type { PaperCornerChip, PaperCornerFold, PaperEdge, PaperNick } from '../lib/paper-wear';
import { getPaperWear } from '../lib/paper-wear';

interface Props {
  number: number;
}

const { number } = Astro.props;
const wear = getPaperWear(number);

function maskUri(viewWidth: number, viewHeight: number, path: string): string {
  const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 ${viewWidth} ${viewHeight}'><path d='${path}' fill='#fff'/></svg>`;
  return `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
}

/**
 * Each bite is drawn twice: a sepia twin stretched by the toning scale sits
 * underneath, and the room-colored bite covers all but its outer fringe, so
 * a sliver of browning hugs the torn boundary.
 */
function edgeStyle(edge: PaperEdge, toningScale = 1): string {
  const horizontal = edge.side === 'top' || edge.side === 'bottom';
  const width = horizontal ? edge.tileLength : edge.depth;
  const height = horizontal ? edge.depth : edge.tileLength;
  const depth = (edge.depth * toningScale).toFixed(1);
  const maskWidth = horizontal ? edge.tileLength : Number(depth);
  const maskHeight = horizontal ? Number(depth) : edge.tileLength;
  return [
    `--edge-mask: ${maskUri(width, height, edge.path)}`,
    `--edge-size: ${maskWidth}px ${maskHeight}px`,
    `--edge-depth: ${depth}px`
  ].join('; ');
}

function nickStyle(nick: PaperNick, toningScale = 1): string {
  const horizontal = nick.side === 'top' || nick.side === 'bottom';
  const width = horizontal ? nick.width : nick.depth;
  const height = horizontal ? nick.depth : nick.width;
  const along = nick.width * (1 + (toningScale - 1) * 0.55);
  const grown = (value: number, alongEdge: boolean) =>
    (value * (alongEdge ? 1 + (toningScale - 1) * 0.55 : toningScale)).toFixed(1);
  const across = `calc(${nick.offset}% - ${(along / 2).toFixed(1)}px)`;
  const place =
    nick.side === 'top'
      ? `inset-block-start: 0; inset-inline-start: ${across}`
      : nick.side === 'bottom'
        ? `inset-block-end: 0; inset-inline-start: ${across}`
        : nick.side === 'left'
          ? `inset-inline-start: 0; inset-block-start: ${across}`
          : `inset-inline-end: 0; inset-block-start: ${across}`;
  return [
    place,
    `inline-size: ${grown(width, horizontal)}px`,
    `block-size: ${grown(height, !horizontal)}px`,
    `--bite-mask: ${maskUri(width, height, nick.path)}`
  ].join('; ');
}

function chipStyle(chip: PaperCornerChip, toningScale = 1): string {
  const [block, inline] = chip.corner.split('-');
  const size = (chip.size * (1 + (toningScale - 1) * 0.7)).toFixed(1);
  return [
    `inset-block-${block === 'top' ? 'start' : 'end'}: 0`,
    `inset-inline-${inline === 'left' ? 'start' : 'end'}: 0`,
    `inline-size: ${size}px`,
    `block-size: ${size}px`,
    `--bite-mask: ${maskUri(chip.size, chip.size, chip.path)}`
  ].join('; ');
}

const ink = (alpha: number) =>
  `color-mix(in oklab, var(--color-ink) ${(alpha * 100).toFixed(1)}%, transparent)`;
const light = (alpha: number) => `rgb(255 255 255 / ${(alpha * 100).toFixed(1)}%)`;

/**
 * The fold block is rendered 1.4x larger than the visible fold so the
 * trailing cast shadow fades out before it can clip against the block
 * boundary and leave a seam. Stops are px distances along the gradient
 * axis; the crease line sits at size / sqrt(2) from the corner tip.
 */
function foldStyle(fold: PaperCornerFold): string {
  const angle = {
    'top-left': 135,
    'top-right': 225,
    'bottom-right': 315,
    'bottom-left': 45
  }[fold.corner];
  const block = Math.ceil(fold.size * 1.4);
  const creaseAt = fold.size * 0.7071;
  const stop = (px: number) => `${px.toFixed(1)}px`;
  return [
    `inset-block-${fold.corner.startsWith('top') ? 'start' : 'end'}: 0`,
    `inset-inline-${fold.corner.endsWith('left') ? 'start' : 'end'}: 0`,
    `inline-size: ${block}px`,
    `block-size: ${block}px`,
    `background-image: linear-gradient(${angle}deg, ` +
      [
        `${light(fold.liftAlpha)} 0`,
        `${light(fold.liftAlpha * 0.55)} ${stop(creaseAt * 0.62)}`,
        `transparent ${stop(creaseAt * 0.94)}`,
        `${ink(fold.contactAlpha * 1.6)} ${stop(creaseAt - 1.2)}`,
        `${ink(fold.contactAlpha * 1.9)} ${stop(creaseAt)}`,
        `${light(fold.rimAlpha)} ${stop(creaseAt + 1.1)}`,
        `${ink(fold.contactAlpha)} ${stop(creaseAt + 4.5)}`,
        `transparent ${stop(creaseAt * 1.24)}`
      ].join(', ') +
      ')'
  ].join('; ');
}
---

<div
  class="paper-wear"
  data-paper-wear={number}
  data-wear-signature={wear.signature}
  style={`--wear-toning-alpha: ${wear.toning.alpha}`}
  aria-hidden="true"
>
  {wear.cornerFold && <div class="paper-wear__fold" style={foldStyle(wear.cornerFold)}></div>}
  {wear.edges.map((edge) => (
    <div
      class={`paper-wear__edge-toning paper-wear__edge--${edge.side}`}
      style={edgeStyle(edge, wear.toning.scale)}
    ></div>
  ))}
  {wear.nicks.map((nick) => (
    <div class="paper-wear__bite-toning" style={nickStyle(nick, wear.toning.scale)}></div>
  ))}
  {wear.cornerSofteners.map((chip) => (
    <div class="paper-wear__bite-toning" style={chipStyle(chip, wear.toning.scale)}></div>
  ))}
  {wear.edges.map((edge) => (
    <div class={`paper-wear__edge paper-wear__edge--${edge.side}`} style={edgeStyle(edge)}></div>
  ))}
  {wear.nicks.map((nick) => (
    <div class="paper-wear__bite" style={nickStyle(nick)}></div>
  ))}
  {wear.cornerSofteners.map((chip) => (
    <div class="paper-wear__bite" style={chipStyle(chip)}></div>
  ))}
</div>
