{
  "name": "publius-federalist-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "dev": "ASTRO_DEV_BACKGROUND=0 ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "generate:masthead": "node scripts/generate-masthead.mjs",
    "generate:printings": "node scripts/generate-printings.mjs",
    "generate:social-cards": "node scripts/generate-social-cards.mjs",
    "generate:x-header": "node scripts/generate-x-header.mjs",
    "generate:email-content": "node scripts/generate-email-content.mjs",
    "build": "pnpm validate:content && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:content": "node scripts/validate-content.mjs",
    "verify:analytics-output": "node scripts/verify-analytics-output.mjs",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check && pnpm verify:analytics-output && pnpm test"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "0.3.3",
    "@fontsource/im-fell-dw-pica": "^5.2.6",
    "@fontsource/im-fell-english": "5.2.6",
    "@fontsource/libre-caslon-display": "5.2.7",
    "@fontsource/libre-caslon-text": "5.2.7",
    "astro": "7.0.7",
    "justif": "0.5.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "22.19.15",
    "@types/opentype.js": "1.3.8",
    "jsdom": "29.1.1",
    "opentype.js": "1.3.4",
    "sharp": "0.35.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
